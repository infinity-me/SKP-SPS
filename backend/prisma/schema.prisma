generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String?  @unique
  password  String?  // Made optional for Google users
  role      String   // admin, teacher, student, guest
  googleId  String?  @unique
  profilePic String? // URL to profile picture
  isVerified Boolean @default(false)
  schoolId  String?  @unique
  createdAt DateTime @default(now())
  
  studentProfile Student?
  teacherProfile Teacher?
}

model Student {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id])
  admissionNo  String   @unique
  class        String
  section      String
  rollNo       Int?
  dob          DateTime?
  address      String?
  parentName   String?
  phone        String?
  photo        String?  @db.Text  // base64 or URL
  achievements Json?    // List of student achievements
  isTopper     Boolean  @default(false)
  topperYear   String?
  topperPercent String?
  topperRank   String?  // e.g. "1st Rank", "Joint 1st Rank"
  topperMarks  String?  // e.g. "570/600"
  topperClass  String?  // e.g. "Class X", "Class XII"
  
  fees         Fee[]
  attendance   Attendance[]
  results      Result[]
}

model Teacher {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id])
  staffId      String   @unique
  designation  String
  qualification String
  subject      String?
  experience   String?
  photo        String?  @db.Text  // base64 or URL
  achievements Json?    // List of teacher achievements
}

model Fee {
  id          Int      @id @default(autoincrement())
  studentId   Int
  student     Student  @relation(fields: [studentId], references: [id])
  amount      Float
  type        String
  status      String   // paid, pending, partial
  dueDate     DateTime
}

model FeeStructure {
  id          Int      @id @default(autoincrement())
  className   String   // e.g. "Nursery", "Class 1"
  feeType     String   // e.g. "Monthly Tuition", "Examination"
  amount      Float
  description String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model Attendance {
  id          Int      @id @default(autoincrement())
  studentId   Int
  student     Student  @relation(fields: [studentId], references: [id])
  date        DateTime
  status      String   // present, absent, late
  period      Int?
}

model Result {
  id          Int      @id @default(autoincrement())
  studentId   Int
  student     Student  @relation(fields: [studentId], references: [id])
  subject     String
  marks       Int
  total       Int
  term        String
}

model Circular {
  id          Int      @id @default(autoincrement())
  title       String
  category    String
  date        DateTime @default(now())
  description String
}

model Admission {
  id           Int      @id @default(autoincrement())
  firstName    String
  lastName     String
  email        String
  phone        String
  class        String
  previousSchool String?
  status       String   @default("pending") // pending, reviewed, accepted
  createdAt    DateTime @default(now())
}

model TeacherApplication {
  id            Int      @id @default(autoincrement())
  fullName      String
  email         String
  phone         String
  subject       String
  qualification String
  experience    String   // e.g., "5 years"
  resumeUrl     String   // URL to the resume (Drive link, etc.)
  status        String   @default("pending") // pending, reviewed, shortlisted, rejected
  createdAt     DateTime @default(now())
}

model Notice {
  id        Int      @id @default(autoincrement())
  message   String
  type      String   @default("info") // info, warning, success, urgent
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Photo {
  id        Int      @id @default(autoincrement())
  url       String
  caption   String
  category  String
  createdAt DateTime @default(now())
}

model Stationery {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  price       Float
  stock       Int      @default(0)
  category    String
  imageUrl    String?
  createdAt   DateTime @default(now())
}

model Order {
  id           Int      @id @default(autoincrement())
  customerName String
  email        String
  phone        String
  items        Json     // List of items as JSON
  total        Float
  status       String   @default("pending") // pending, completed, cancelled
  createdAt    DateTime @default(now())
}

model CalendarEvent {
  id          Int      @id @default(autoincrement())
  title       String
  date        DateTime
  type        String   // holiday, exam, event, academic
  description String?
  createdAt   DateTime @default(now())
}

model Page {
  id           Int      @id @default(autoincrement())
  title        String
  slug         String   @unique
  status       String   @default("Published") // Draft, Published
  blocks       Json?    // Array of sections: [{ type: 'hero', props: { ... } }, { type: 'features', props: { ... } }]
  lastModified DateTime @updatedAt
  createdAt    DateTime @default(now())
}

model PopupSetting {
  id         Int      @id @default(1)
  isActive   Boolean  @default(true)
  title      String   @default("Admissions Open")
  subtitle   String   @default("For Session 2026-2027")
  buttonText String   @default("Apply Now")
  buttonLink String   @default("/admission")
  images     Json     // Will store an array of base64 image strings or URLs
  updatedAt  DateTime @updatedAt
}

model BotRule {
  id        Int      @id @default(autoincrement())
  trigger   String   // Keywords separated by commas
  response  String   @db.Text
  category  String   @default("General")
  language  String   @default("Bilingual")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Admission Settings ─────────────────────────────────────────────
model AdmissionSetting {
  id               Int      @id @default(1)
  isOpen           Boolean  @default(true)
  bannerText       String   @default("Admissions Open for Session 2026–27")
  lastDateText     String   @default("Last Date: 31 May 2026")
  seats            Json     // { "Nursery": 30, "Class I": 40, ... }
  updatedAt        DateTime @updatedAt
}

// ─── Site Content Editor ─────────────────────────────────────────────
model SiteContent {
  id        Int      @id @default(autoincrement())
  key       String   @unique  // e.g. "hero_title", "principal_name", "school_tagline"
  label     String            // Human readable label shown in admin
  value     String   @db.Text
  section   String            // "homepage", "about", "contact"
  updatedAt DateTime @updatedAt
}

// ─── Gallery Categories ───────────────────────────────────────────────
model PhotoCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// ─── Board Result Toppers ─────────────────────────────────────────────
model BoardTopper {
  id          Int      @id @default(autoincrement())
  name        String
  boardClass  String   // e.g. "Class X", "Class XII"
  year        String   // e.g. "2026"
  rank        String?  // e.g. "Joint 1st Rank", "2nd Rank"
  marks       String?  // e.g. "570/600"
  percentage  String   // e.g. "95" or "93.33"
  photo       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
